{
  "Version": "2012-10-17",
  "Id": "MyPolicy",
  "Statement": [
    {
      "Sid": "Stmt1",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::examplebucket",
      "Principal": {
        "AWS": "*"
      }
    },
    {
      "Sid": "Stmt2",
      "Effect": "Deny",
      "NotAction": [
        "ec2:*",
        "s3:*",
        "rds:*"
      ],
      "Resource": [
        "arn:aws:ec2:*:*:instance/*",
        "arn:aws:s3:*:*:bucket/*",
        "arn:aws:rds:*:*:db/*"
      ],
      "Principal": {
        "AWS": [
          "arn:aws:iam::123456789012:root",
          "arn:aws:iam::123456789012:user/*"
        ],
        "Federated": [
          "dacut@kanga.org"
        ],
        "Service": [
          "ec2.amazonaws.com",
          "edgelambda.amazonaws.com",
          "lambda.amazonaws.com"
        ]
      },
      "Condition": {
        "DateGreaterThan": {
          "aws:CurrentTime": "2012-10-17T00:00:00Z"
        },
        "StringEqualsIfExists": {
          "aws:userid": [
            "dacut",
            "dacut2"
          ]
        }
      }
    }
  ]
}